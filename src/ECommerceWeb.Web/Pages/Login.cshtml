@page
@{
    Layout = "Shared/_MyECommerceLayout";
}

<!-- Sadece bu sayfaya özel Login CSS'ini ekliyoruz -->
@section Styles {
    <link rel="stylesheet" href="~/trendyol-ecoomerce/login.css">
}

<!-- Login kısmı -->
<p style="text-align: center;margin-top: 2%;font-size: 18px;font-weight: 500;">Merhaba,</p>
<p style="text-align: center;">Trendyol’a giriş yap veya hesap oluştur, indirimleri kaçırma!</p>

<div class="container">
    <div class="tabs">
        <div class="tab active log-in" onclick="showForm('login')">Giriş Yap</div>
        <div class="tab sign-up" onclick="showForm('register')">Üye Ol</div>
    </div>

    <!-- Giriş Yap -->
    <div id="login" class="form-container active">
        <div class="form-group">
            <label for="email">E-Posta</label>
            <input type="email" id="email">
        </div>
        <div class="form-group">
            <label for="password">Şifre</label>
            <div style="display: flex;">
                <input type="password" id="password">
                <img style="width: 20px;margin-left: -40px;height: 20px;margin-top: 10px;" src="~/trendyol-ecoomerce/img/eye-closed.png" alt="">
            </div>
        </div>
        <a href="" style="margin-left: 240px;font-size: 15px;text-decoration:underline;"> Şifremi Unuttum </a>
        <button class="button">GİRİŞ YAP</button>
        <div style="display: flex; gap: 10px;margin-top: 3%;">
            <!-- Facebook Girişi -->
            <div style="display: flex; align-items: center; border: 1px solid lightgray; padding: 5px; width: 180px; border-radius: 5px;">
                <i style="font-size: 30px; color: #1877F2; margin-right: 10px;margin-left: 20px;" class="fa-brands fa-facebook"></i>
                <p style="margin-left: 10px; font-weight: bold;">Facebook <br><span style="font-weight: normal;">ile giriş yap</span></p>
            </div>

            <!-- Google Girişi -->
            <div style="display: flex; align-items: center; border: 1px solid lightgray; padding: 5px; width: 180px; border-radius: 5px;">
                <i style="font-size: 30px; color: #DB4437; margin-right: 10px;margin-left: 20px;" class="fa-brands fa-google"></i>
                <p style="margin-left: 10px; font-weight: bold;">Google <br><span style="font-weight: normal;">ile giriş yap</span></p>
            </div>
        </div>
        <p style="font-size: 14px;text-align: center;margin-top: 2%;">
            Üye olmadan verilen siparişlerin takibi için
            <a href="" style="text-decoration:line-through;">tıklayınız.</a>
        </p>
    </div>

    <!-- Üye ol -->
    <div id="register" class="form-container">
        <div class="form-group">
            <label for="reg-email">E-Posta</label>
            <input type="email" id="reg-email">
        </div>
        <div class="form-group">
            <label for="reg-password">Şifre</label>
            <div style="display: flex;">
                <input type="password" id="reg-password">
                <img style="width: 20px;margin-left: -40px;height: 20px;margin-top: 10px;" src="~/trendyol-ecoomerce/img/eye-closed.png" alt="">
            </div>
            <small>Şifreniz en az 10 karakter olmalı. 1 büyük harf, 1 küçük harf ve rakam içermelidir.</small>
        </div>
        <div class="form-group">
            <label>Cinsiyet (Opsiyonel)</label>
            <div>
                <button class="cinsiyet-button" style="width: 45%;padding: 10px;border-radius: 5px;">Kadın</button>
                <button class="cinsiyet-button" style="width: 45%;padding: 10px;border-radius: 5px;">Erkek</button>
            </div>
        </div>
        <div class="checkbox-group">
            <input class="uye-checkbox" type="checkbox" id="offer">
            <label style="font-size: 11px;font-weight: 300;" for="offer">Avantajlı tekliflere izin veriyorum.</label>
        </div>
        <div class="checkbox-group">
            <input class="uye-checkbox" type="checkbox" id="email-accept">
            <label style="font-size: 11px;font-weight: 300;" for="email-accept">Elektronik ileti gönderilmesini kabul ediyorum.</label>
        </div>
        <div class="checkbox-group">
            <input class="uye-checkbox" type="checkbox" id="privacy">
            <label style="font-size: 11px;font-weight: 300;" for="privacy">Aydınlatma metnini okudum ve anladım.</label>
        </div>
        <button style="margin-top: 2%;" class="button">ÜYE OL</button>
        <div class="social-login">
            <div style="display: flex; align-items: center; border: 1px solid lightgray; padding: 5px; width: 180px; border-radius: 5px;">
                <i style="font-size: 30px; color: #1877F2; margin-right: 10px;margin-left: 20px;" class="fa-brands fa-facebook"></i>
                <p style="margin-left: 10px; font-weight: bold;">Facebook <br><span style="font-weight: normal;">ile giriş yap</span></p>
            </div>

            <!-- Google Girişi -->
            <div style="display: flex; align-items: center; border: 1px solid lightgray; padding: 5px; width: 180px; border-radius: 5px;">
                <i style="font-size: 30px; color: #DB4437; margin-right: 10px;margin-left: 20px;" class="fa-brands fa-google"></i>
                <p style="margin-left: 10px; font-weight: bold;">Google <br><span style="font-weight: normal;">ile giriş yap</span></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showForm(form) {
            document.getElementById('login').classList.remove('active');
            document.getElementById('register').classList.remove('active');
            document.querySelector('.tab.active').classList.remove('active');

            if (form === 'login') {
                document.getElementById('login').classList.add('active');
                document.querySelector('.tabs .tab:nth-child(1)').classList.add('active');
            } else {
                document.getElementById('register').classList.add('active');
                document.querySelector('.tabs .tab:nth-child(2)').classList.add('active');
            }
        }
    </script>
}